# Required: Keycloak server and client credentials
# Base URL of your Keycloak server, without /realms/... (legacy WildFly installs: include /auth)
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=your-client-secret

# Optional: Server URL (defaults to http://localhost:3333)
# SERVER_URL=http://localhost:3333

# Optional: Port (defaults to 3333)
# PORT=3333
